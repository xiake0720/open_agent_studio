APP_NAME=OpenAgent Studio
APP_ENV=dev
APP_DEBUG=true

API_HOST=127.0.0.1
API_PORT=9099

DATABASE_URL=sqlite+aiosqlite:///./data/open_agent_studio.db

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Authentication
AUTH_COOKIE_NAME=oas_session
AUTH_SESSION_DAYS=7
LOGIN_CAPTCHA_AFTER_FAILURES=3
LOGIN_CAPTCHA_TTL_SECONDS=300

# LLM API Keys
GLM_API_KEY=your_glm_api_key
QWEN_API_KEY=your_qwen_api_key
NVIDIA_KEY=your_nvidia_api_key
CUSTOM_MODEL_API_KEY=your_custom_model_api_key
IMAGE_MODEL_API_KEY=your_image_model_api_key
