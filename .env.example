APP_NAME=OpenAgent Studio
APP_ENV=dev
APP_DEBUG=true

API_HOST=127.0.0.1
API_PORT=9099

DATABASE_URL=sqlite+aiosqlite:///./data/open_agent_studio.db

BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Authentication
AUTH_COOKIE_NAME=oas_session
AUTH_SESSION_DAYS=7
LOGIN_CAPTCHA_AFTER_FAILURES=3
LOGIN_CAPTCHA_TTL_SECONDS=300

# Agent runtime
AGENT_RUN_TIMEOUT_SECONDS=120
AGENT_TOKEN_CHUNK_CHARS=256
AGENT_TOKEN_CHUNK_SECONDS=1
NVIDIA_IMAGE_TIMEOUT_SECONDS=90

# LLM API Keys
NVIDIA_KEY=your_nvidia_api_key

DEFAULT_ADMIN_USERNAME=...
DEFAULT_ADMIN_PASSWORD=...
